# App
NODE_ENV=production
PORT=3001
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=8h

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hr_grievance
POSTGRES_USER=hr_user
POSTGRES_PASSWORD=change_me_db_password

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# DigitalOcean Spaces (S3-compatible)
DO_SPACES_KEY=your_do_spaces_access_key
DO_SPACES_SECRET=your_do_spaces_secret_key
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=hr-grievance-docs

# Google OAuth (create at console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Must match the redirect URI you set in Google Cloud Console
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback
# Where to send the user after Google auth (frontend URL)
FRONTEND_URL=https://your-domain.com

# Keka HRMS
KEKA_API_BASE_URL=https://your-org.keka.com/api
KEKA_API_KEY=your_keka_api_key
KEKA_TENANT_ID=your_keka_tenant_id

# Email (for escalation notifications — uses nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hr-bot@yourcompany.com
SMTP_PASS=your_app_password
EMAIL_FROM=HR Bot <hr-bot@yourcompany.com>

# Slack (Phase 2 — leave blank for Phase 1)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Frontend (must be set at build time)
VITE_API_URL=https://your-domain.com/api
